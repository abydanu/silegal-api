generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StatusAkun {
  aktif
  non_aktif
}

enum ProgramStudi {
  ILMU_HUKUM
  MANAJEMEN
  AKUNTANSI
  ADMINISTRASI_NEGARA
  ILMU_KOMUNIKASI
  AGROTEKNOLOGI
  TEKNIK_MESIN
  TEKNIK_SIPIL
  MANAJEMEN_INFORMATIKA
}

enum Fakultas {
  HUKUM
  EKONOMI
  ILMU_SOSIAL_DAN_ILMU_POLITIK
  PERTANIAN
  TEKNIK
}

model Admin {
  id_admin    Int        @id @default(autoincrement())
  nama_admin  String     @db.VarChar(50)
  status_akun StatusAkun @default(aktif)
  role        String     @db.VarChar(10) @default("admin")
  username    String     @db.VarChar(10) @unique
  password    String     @db.VarChar(255)
  createdAt   DateTime   @default(now())

  @@map("admin")
}

model DataLegalisir {
  id_data           Int          @id @default(autoincrement())
  tanggal_pengajuan DateTime     @db.Date
  nomor_surat       String       @db.VarChar(50)
  nama_mahasiswa    String       @db.VarChar(50)
  tempat_lahir      String       @db.VarChar(15)
  nim               String       @db.VarChar(15)
  tgl_lahir         DateTime     @db.Date
  tgl_kelulusan     DateTime     @db.Date
  program_studi     ProgramStudi
  fakultas          Fakultas
  nomor_seri_ijazah String       @db.VarChar(20)
  sebanyak_ijazah   Int          @default(0)
  sebanyak_transkip Int          @default(0)
  sebanyak_akreditasi Int        @default(0)
  jumlah_legalisir  Int
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@map("data_legalisir")
}

model DataPengajuan {
  id_data              Int          @id @default(autoincrement())
  tanggal_pengajuan    DateTime     @db.Date
  nomor_surat          String       @db.VarChar(50)
  nama_mahasiswa       String       @db.VarChar(50)
  tempat_lahir         String       @db.VarChar(15)
  nim                  String       @db.VarChar(15)
  tgl_lahir            DateTime     @db.Date
  alamat_rumah         String       @db.VarChar(50)
  semester             String       @db.VarChar(10)
  program_studi        ProgramStudi
  fakultas             Fakultas
  thn_akademik         String       @db.VarChar(25)
  keterangan_keperluan String       @db.VarChar(300)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@map("data_pengajuan")
}