{
  "name": "api-silegal",
  "scripts": {
    "dev": "bun run --watch dev.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "bun run prisma/seed/seed.ts",
    "vercel-build": "prisma generate && bun build src/index.ts --outdir dist --target node"
  },
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@types/pg": "^8.16.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.3.1",
    "hono": "^4.12.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bun": "latest",
    "@types/node": "^25.3.0",
    "prisma": "^7.4.1"
  }
}